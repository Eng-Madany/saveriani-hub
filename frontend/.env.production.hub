# Environment for Apache deployment in /hub/ subdirectory
# Copy this to .env before running 'yarn build'

# Your backend API URL (update with your actual backend server)
REACT_APP_BACKEND_URL=https://your-backend-server.com

# Base path for React Router (must match your subdirectory)
REACT_APP_BASE_PATH=/hub

# Disable health check for static deployment
ENABLE_HEALTH_CHECK=false
